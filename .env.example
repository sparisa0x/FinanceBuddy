# Supabase Configuration (REQUIRED)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Auth Secrets (REQUIRED for backend auth)
JWT_SECRET=replace_with_strong_random_string
REFRESH_TOKEN_SECRET=replace_with_strong_random_string

# Client App (OPTIONAL)
CLIENT_ORIGIN=http://localhost:5173
COOKIE_SECURE=false

# Email Notifications (OPTIONAL - for user registration alerts)
SMTP_EMAIL=your_outbound_address@example.com
SMTP_PASSWORD=your_smtp_password_or_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true

# Server Configuration (OPTIONAL)
PORT=3001
